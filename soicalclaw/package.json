{
  "name": "clawsocial",
  "version": "1.0.0",
  "description": "ClawSocial 小龙虾认证考试 - 等级考试与技能认证平台",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:frontend": "cd frontend && pnpm dev",
    "dev:backend": "cd backend && pnpm dev",
    "build": "pnpm build:backend && pnpm build:frontend",
    "build:frontend": "cd frontend && pnpm build",
    "build:backend": "cd backend && pnpm build"
  },
  "keywords": ["clawsocial", "openclaw", "crayfish", "xiaolongxia", "community"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
