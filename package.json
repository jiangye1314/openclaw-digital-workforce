{
  "name": "today-i-am-shrimp-boss",
  "productName": "今天我是虾老板",
  "version": "1.0.0",
  "description": "今天我是虾老板 - 数字员工团队管理系统",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared",
    "openclaw"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm dev:openclaw\" \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:all": "concurrently \"pnpm dev:openclaw\" \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:frontend": "cd frontend && pnpm dev",
    "dev:backend": "cd backend && pnpm dev",
    "dev:openclaw": "cd openclaw && pnpm dev",
    "build": "pnpm build:shared && pnpm build:backend && pnpm build:openclaw && pnpm build:frontend",
    "build:shared": "cd shared && pnpm build",
    "build:frontend": "cd frontend && pnpm build",
    "build:backend": "cd backend && pnpm build",
    "build:openclaw": "cd openclaw && pnpm build",
    "setup": "pnpm install && pnpm setup:openclaw",
    "setup:openclaw": "cd openclaw && pnpm install",
    "electron:dev": "concurrently \"pnpm dev:frontend\" \"pnpm dev:backend\" \"wait-on tcp:5173 && electron electron/main.js\"",
    "build:electron": "node scripts/build-backend.js && pnpm build:frontend",
    "dist:mac": "pnpm build:electron && electron-builder --mac --config electron-builder.json",
    "dist:win": "pnpm build:electron && electron-builder --win --config electron-builder.json"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.3",
    "tsdown": "^0.21.0",
    "wait-on": "^9.0.4"
  }
}
